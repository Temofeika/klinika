// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Patient {
  id            String   @id @default(cuid())
  firstName     String
  lastName      String
  phone         String   @unique
  email         String?
  dateOfBirth   DateTime?
  gender        String?
  notes         String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  lastMessageAt DateTime @default(now())
  
  medicalRecord String?  // Stores JSON string of all clinical records
  
  doctor        Doctor?  @relation(fields: [doctorId], references: [id])
  doctorId      String?

  messages      Message[]
  messengerAccounts MessengerAccount[]
}

model Doctor {
  id        String    @id @default(cuid())
  firstName String
  lastName  String
  position  String    // e.g., "Терапевт", "Кардиолог"
  username  String    @unique
  patients  Patient[]
}

model Message {
  id          String   @id @default(cuid())
  content     String
  source      String   // "TELEGRAM", "MAX"
  timestamp   DateTime @default(now())
  isIncoming  Boolean  @default(true)
  isRead      Boolean  @default(false)
  status      String   @default("SENT") // "PENDING", "SENT"
  
  patient     Patient  @relation(fields: [patientId], references: [id])
  patientId   String
}

model MessengerAccount {
  id          String   @id @default(cuid())
  platform    String   // "TELEGRAM", "MAX"
  externalId  String   // e.g., telegram chat id or phone number
  
  patient     Patient  @relation(fields: [patientId], references: [id])
  patientId   String

  @@unique([platform, externalId])
}

model SystemSetting {
  key   String @id
  value String
}

model Template {
  id        String   @id @default(cuid())
  name      String
  content   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
